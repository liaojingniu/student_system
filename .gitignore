# ==========================================
# 1. 依赖库与编译产物 (体积巨大，绝对不要让 AI 扫描)
# ==========================================
node_modules/
/dist/
/build/
/out/
/.next/
/.nuxt/
/.output/

# ==========================================
# 2. 静态资源与媒体文件 (AI 无法通过文本理解代码含义，白占 Token)
# ==========================================
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.ico
*.webp
*.mp3
*.mp4
*.pdf
*.zip
*.tar.gz

# ==========================================
# 3. 字体与大型二进制文件
# ==========================================
*.ttf
*.woff
*.woff2
*.eot
*.otf
*.wasm

# ==========================================
# 4. 日志、缓存与数据库本地文件
# ==========================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.sqlite
*.db

# ==========================================
# 5. IDE、系统与包管理器锁文件 (文件极大，AI 几乎不需要读)
# ==========================================
package-lock.json
yarn.lock
pnpm-lock.yaml
.DS_Store
Thumbs.db
.idea/
.vscode/

# ==========================================
# 6. 环境配置与敏感信息 (保护隐私 + 防干扰)
# ==========================================
.env
.env.*
!.env.example
*.pem
*.key